{
  "name": "splitwise-mcp",
  "description": "Create and manage Splitwise expenses, splits, and groups directly from Claude.",
  "tools": [
    {
      "name": "list_groups",
      "description": "List all Splitwise groups you belong to, with their IDs and names.",
      "inputSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "list_group_members",
      "description": "List members of a Splitwise group with their user IDs and names.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "group_id": { "type": "integer", "description": "Splitwise group ID" }
        },
        "required": ["group_id"]
      }
    },
    {
      "name": "create_group",
      "description": "Create a new Splitwise group and optionally add members.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Display name for the group" },
          "group_type": { "type": "string", "enum": ["apartment", "house", "trip", "other"], "description": "Type of group (default: other)" },
          "members": { "type": "array", "items": { "type": "object" }, "description": "List of {user_id: int} to add" }
        },
        "required": ["name"]
      }
    },
    {
      "name": "create_expense",
      "description": "Create a Splitwise expense in a group with per-user splits, date, and notes.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "cost": { "type": "string", "description": "Total amount e.g. '42.50'" },
          "group_id": { "type": "integer" },
          "paid_by_user_id": { "type": "integer" },
          "splits": { "type": "array", "items": { "type": "object" }, "description": "List of {user_id, owed_share} - must sum to cost" },
          "date": { "type": "string", "description": "YYYY-MM-DD - auto-normalized to noon UTC" },
          "notes": { "type": "string", "description": "Extra detail shown in expense notes field" }
        },
        "required": ["description", "cost", "group_id", "paid_by_user_id", "splits"]
      }
    },
    {
      "name": "update_expense",
      "description": "Update any field on an existing Splitwise expense.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "expense_id": { "type": "integer" },
          "description": { "type": "string" },
          "cost": { "type": "string" },
          "date": { "type": "string", "description": "YYYY-MM-DD" },
          "notes": { "type": "string" },
          "group_id": { "type": "integer" },
          "paid_by_user_id": { "type": "integer" },
          "splits": { "type": "array", "items": { "type": "object" } }
        },
        "required": ["expense_id"]
      }
    },
    {
      "name": "delete_expense",
      "description": "Delete a Splitwise expense by ID.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "expense_id": { "type": "integer" }
        },
        "required": ["expense_id"]
      }
    }
  ]
}
